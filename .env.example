# Optional but recommended for persistent storage (Upstash Redis)
# Supported variable names:
# - UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# - KV_REST_API_URL / KV_REST_API_TOKEN (Vercel/Upstash style)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional API port override
# PORT=8787

# Optional Redis read-through cache TTL (milliseconds) for API-side in-memory cache
# Helps reduce repeated Upstash reads on identical listing/moderation queries.
# REDIS_CACHE_TTL_MS=15000

# Required to enable protected manual moderation endpoints
# Header accepted: x-moderation-token (or Authorization: Bearer <token>)
MODERATION_API_TOKEN=

# Optional GitHub-native notifications for pending moderation submissions.
# If both values below are set, the API will create one GitHub issue per new pending submission.
# Required token scope: repository issues write on the target repo.
GITHUB_NOTIFY_REPO=
GITHUB_NOTIFY_TOKEN=

# GitHub Actions fallback names (useful because Actions secrets/variables cannot start with GITHUB_)
# RGAA_NOTIFY_REPO=
# RGAA_NOTIFY_TOKEN=

# Optional comma-separated GitHub labels for created issues.
# GITHUB_NOTIFY_LABELS=moderation,annuaire-rgaa

# Optional public URL used to generate a direct moderation link in the issue body.
# PUBLIC_APP_URL=https://annuaire-rgaa.fr
